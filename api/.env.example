# JWT — mesmo segredo do auth-api (HMAC-SHA256, mín 32 chars)
JWT_SECRET=

# MongoDB
MONGO_URI=mongodb://localhost:27017/sga-painel
MONGO_FALLBACK_HOST=127.0.0.1
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Server
PORT=4000
NODE_ENV=development

# Cookie — domínio compartilhado com auth-api
COOKIE_DOMAIN=.santos-games.com
AUTH_COOKIE_NAME=sga_auth

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# Produção:
# ALLOWED_ORIGINS=https://painel-adm.santos-games.com,https://auth.santos-games.com

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=home:

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# Codex embarcado
CODEX_HOME=/data/codex-home
CODEX_WORKSPACE_ROOT=/app
CODEX_APP_SERVER_PORT=4545
