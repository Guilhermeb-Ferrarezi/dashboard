# JWT Secret Key
JWT_SECRET=sua_chave_secreta_super_segura_aqui
JWT_EXPIRES_IN=36h

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/seu_banco
MONGO_FALLBACK_HOST=127.0.0.1
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Server Port
PORT=4000

# Node Environment
NODE_ENV=development

COOKIE_DOMAIN=

# Origens permitidas (separadas por vírgula)
# Liste todos os domínios que podem acessar sua API
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Para produção, use algo como:
# ALLOWED_ORIGINS=https://painel-adm.santos-tech.com,https://banco-de-talentos.santos-tech.com

# SSO — segredos compartilhados com cada projeto destino
SSO_JWT_SECRET=
SSO_SHARED_SECRET=
ADMIN_PORTAL_SSO_SECRET=
STUDENT_PORTAL_SSO_SECRET=
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=sso:code:

# Hash (se necessário para outra funcionalidade)
HASH=
