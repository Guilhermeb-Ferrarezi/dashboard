NEXT_PUBLIC_API_URL=https://api.santos-tech.com/api
API_INTERNAL_URL=http://api:4000/api

# Identidade do projeto que vai consumir o code no /auth/sso
SSO_PROJECT_ID=admin-portal

# Segredo compartilhado com a API central
SSO_SHARED_SECRET=

# Fallback legado, se preferir manter o nome antigo no admin portal
ADMIN_PORTAL_SSO_SECRET=

# Destinos apos concluir a troca do codigo
SSO_SUCCESS_PATH_ADMIN=/admin/users
SSO_SUCCESS_PATH_USER=/home
